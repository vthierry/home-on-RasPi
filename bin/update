# Updates the present system installation

## Ensures the ~/bin scripts are executable
chmod a+rx ~/bin/[a-z]*

## Cleans unused or temporary home directories and files
rmdir --ignore-fail-on-non-empty ~/{Documents,Downloads,Music,Pictures,Public,Templates,Videos,.emacs.d}
/bin/rm -rf ~/{.profile,.bash_logout,.xsession-errors,.Xauthority,.cache}
~/bin/clean ~

## Removes unused packages
sudo apt remove firefox raspberryconnect squeekboard geany thonny eom piclone rpi-imager rp-bookshelf rp-prefapps userguide

## Installs used packages
sudo apt update -q -y  ; sudo apt full-upgrade -q -y ; sudo apt autoremove -q -y ; sudo apt-file update
## - Installs file manipulation used packages
sudo apt install git nodejs rclone
## - Installs media and document manipulation packages
sudo apt install pdftk gimp simple-scan imagemagick audacity shotcut ffmpeg simplescreenrecorder
## - Installs the https://github.com/vthierry/idnai packages
sudo apt install emacs arduino kicad 


