#!/bin/bash

# Usage: update ; Installs or updates the home directory to work as a tiny workstation.

# THIS IS MY OWN PERSONAL PARTICULAR UPDATE MECHANISM PLEASE ADAPT BEFORE USE
#  (unless nothing is catastrophic if you do not)

